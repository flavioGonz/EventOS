{
  "name": "eventos-desktop",
  "version": "1.0.0",
  "description": "EventOS · ARC — consola de escritorio (Electron) con decode por GPU, multi-monitor, bandeja y hotkeys.",
  "main": "main.js",
  "author": "EventOS",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis",
    "dist:linux": "electron-builder --linux AppImage"
  },
  "devDependencies": {
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "uy.eventos.arc.desktop",
    "productName": "EventOS ARC",
    "directories": { "output": "dist" },
    "files": ["main.js", "preload.js", "config.json", "assets/**/*"],
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EventOS ARC"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "assets/icon.png",
      "category": "Utility"
    }
  }
}
