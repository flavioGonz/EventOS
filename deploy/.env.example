# EventOS — variables de entorno del backend (API)
# Copia este archivo a /etc/eventos/eventos.env (chmod 600, dueño root)
# El instalador (deploy/install.sh) lo genera automáticamente.

# Bind y entorno
HOST=127.0.0.1            # la API escucha solo en localhost; nginx la expone
PORT=4010
NODE_ENV=production

# Bus de eventos (Redis). Vacío = fallback en memoria (el server arranca igual).
REDIS_URL=redis://127.0.0.1:6379

# Token de ingesta de dispositivos (webhooks). Lo envían las cámaras/alarmas
# por header X-Ingest-Token o como ?token= en la URL. Genéralo con:
#   echo "ingest_$(openssl rand -hex 24)"
INGEST_TOKEN=CAMBIAR_token_de_ingesta

# Origen permitido para CORS. En producción: el dominio de nginx (http://eventos.local).
# '*' permite cualquier origen (solo recomendable en LAN cerrada / demo).
CORS_ORIGIN=*
